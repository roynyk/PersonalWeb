<!-- FORM -->
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <h2 class="text-center mb-4 fw-bold">ADD MY PROJECT</h2>

            <form id="projectForm">
                <!-- Project Name -->
                <div class="mb-3">
                    <label class="form-label">Project Name</label>
                    <input type="text" name="projectName" class="form-control" required />
                </div>

                <!-- Date -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" name="startDate" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" name="endDate" class="form-control" required />
                    </div>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="5" required></textarea>
                </div>

                <!-- Technologies -->
                <div class="mb-3">
                    <label class="form-label">Technologies</label>

                    <div class="row">
                        <div class="col-6">
                            <input type="checkbox" name="technologies" value="node" />
                            Node Js
                        </div>
                        <div class="col-6">
                            <input type="checkbox" name="technologies" value="react" />
                            React Js
                        </div>
                        <div class="col-6">
                            <input type="checkbox" name="technologies" value="javascript" />
                            JavaScript
                        </div>
                        <div class="col-6">
                            <input type="checkbox" name="technologies" value="bootstrap" />
                            Bootstrap
                        </div>
                    </div>
                </div>

                <!-- Upload -->
                <div class="mb-3">
                    <label class="form-label">Upload Image</label>
                    <input type="file" name="image" class="form-control" />
                </div>

                <!-- Submit -->
                <div class="text-end">
                    <button type="submit" class="my-btn">Submit</button>
                </div>
            </form>

            <!-- PROJECT LIST -->
            <div class="container mt-5">
                <h2 class="text-center fw-bold mb-4">MY PROJECT</h2>

                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <div class="d-flex flex-wrap gap-2" id="filter-buttons">
                        <button id="btn-all" class="my-btn" onclick="filterProjects('all')">All</button>
                        <button id="btn-node" class="my-btn-outline" onclick="filterProjects('node')">Node JS</button>
                        <button id="btn-react" class="my-btn-outline" onclick="filterProjects('react')">React
                            JS</button>
                        <button id="btn-javascript" class="my-btn-outline"
                            onclick="filterProjects('javascript')">JavaScript</button>
                        <button id="btn-bootstrap" class="my-btn-outline"
                            onclick="filterProjects('bootstrap')">Bootstrap</button>
                    </div>
                    <button class="btn btn-danger" onclick="deleteAllProjects()">
                        Delete All
                    </button>
                </div>
                <!-- rendernya nnti disini -->
                <div id="project-list" class="row g-4"></div>
            </div>
        </div>
    </div>
</div>

<script src="/assets/scripts/script.js"></script>