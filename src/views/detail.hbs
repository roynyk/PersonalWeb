<!-- ini navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-light px-4">
    <i class="navbar-brand fas fa-user"></i>

    <div class="ms-auto">
        <a href="/my-project" class="btn btn-dark">Back</a>
    </div>
</nav>

<!-- CONTENT -->
<div class="container my-5">
    <!-- TITLE -->
    <h1 class="text-center fw-bold mb-5">{{project.name}}</h1>

    <!-- TOP SECTION -->
    <div class="row">
        <!-- IMAGE -->
        <div class="col-md-8">
            <img src="/assets/img/programmer.png" class="img-fluid rounded" alt="project image" />
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-4">
            <h5 class="fw-bold mb-3">Duration</h5>

            <p>
                <i class="fa-solid fa-calendar-days me-2"></i> {{project.startDate}} - {{project.endDate}}
            </p>

            <p>
                <i class="fa-regular fa-clock me-2"></i> {{project.duration}}
            </p>

            <h5 class="fw-bold mt-4 mb-3">Technologies</h5>


            <div class="d-flex flex-wrap gap-3">
                {{#if project.hasNode}}
                <div><i class="fab fa-node-js fa-2x"></i> Node.js</div>
                {{/if}}
                {{#if project.hasReact}}
                <div><i class="fab fa-react fa-2x"></i> React.js</div>
                {{/if}}
                {{#if project.hasJavaScript}}
                <div><i class="fab fa-js fa-2x"></i> JavaScript</div>
                {{/if}}
                {{#if project.hasBootstrap}}
                <div><i class="fab fa-bootstrap fa-2x"></i> Bootstrap</div>
                {{/if}}
            </div>
        </div>
    </div>

    <!-- DESCRIPTION -->
    <div class="mt-5">
        <p style="text-align: justify">{{project.description}}</p>
    </div>
</div>
